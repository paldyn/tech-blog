---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { CollectionEntry } from 'astro:content';
import { postTypeLabel } from '../utils/posts';

interface Props {
  post: CollectionEntry<'posts'>;
  readingTime: string;
  headings?: Array<{ depth: number; slug: string; text: string }>;
}
const { post, readingTime, headings = [] } = Astro.props;
const { title, description, author, pubDate, updatedDate, category, tags } = post.data;
const typeLabel = postTypeLabel(post.data.type);
const tocHeadings = headings.filter((h) => h.slug && h.text);
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <div class:list={['post-shell', { 'has-toc': tocHeadings.length > 0 }]}>
        <div class="post-primary">
          <div class="post-labels">
            <div class:list={['type-badge', post.data.type]}>{typeLabel}</div>
            <div class="category">{category}</div>
          </div>
          <h1>{title}</h1>
          <p class="description">{description}</p>
          <div class="meta">
            <FormattedDate date={pubDate} />
            <span class="sep">·</span>
            <span>{readingTime}</span>
            <span class="sep">·</span>
            <span>{author}</span>
            {updatedDate && (
              <>
                <span class="sep">·</span>
                <span>업데이트 <FormattedDate date={updatedDate} /></span>
              </>
            )}
          </div>
        </div>
      </div>
    </header>

    <div class:list={['post-shell', 'post-main', { 'has-toc': tocHeadings.length > 0 }]}>
      <div class="post-primary post-body prose">
        <slot />
      </div>

      {tocHeadings.length > 0 && (
        <aside class="toc" aria-label="목차">
          <div class="toc-inner">
            <p class="toc-title">ON THIS PAGE</p>
            <nav class="toc-nav">
              {tocHeadings.map((h) => (
                <a href={`#${h.slug}`} class:list={['toc-link', `depth-${h.depth}`]}>{h.text}</a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>

    <div id="image-lightbox" class="image-lightbox" hidden role="dialog" aria-modal="true" aria-label="이미지 확대 보기">
      <button type="button" class="lightbox-close" aria-label="닫기">×</button>
      <img class="lightbox-img" alt="" />
    </div>

    {tags.length > 0 && (
      <footer class="post-footer">
        <div class:list={['post-shell', { 'has-toc': tocHeadings.length > 0 }]}>
          <div class="post-primary">
            <div class="tags">
              {tags.map(t => <span class="tag">#{t}</span>)}
            </div>
          </div>
        </div>
      </footer>
    )}
  </article>
</BaseLayout>

<style>
  .post-header {
    padding: 80px 0 40px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
  }
  .post-header .post-labels {
    display: inline-grid;
    grid-auto-flow: column;
    grid-auto-columns: max-content;
    align-items: center;
    column-gap: 10px;
    margin-bottom: 20px;
    white-space: nowrap;
  }
  .post-header .category {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-bottom: 0;
    line-height: 1;
  }
  .post-header .type-badge {
    width: fit-content;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    line-height: 1;
    padding: 5px 10px;
    margin-bottom: 0;
    text-transform: uppercase;
  }
  .post-header .type-badge.knowledge {
    color: var(--accent-bright);
  }
  .post-header h1 {
    font-size: 38px;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0.01em;
    margin-bottom: 18px;
    color: var(--accent-bright);
  }
  .description {
    font-size: 17px;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 24px;
    font-weight: 300;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
    display: flex;
    gap: 10px;
    align-items: center;
    letter-spacing: 0.08em;
  }
  .sep { opacity: 0.5; }

  .post-shell {
    max-width: var(--wrap-narrow);
    margin: 0 auto;
    padding: 0 40px;
    width: 100%;
  }
  .post-shell.has-toc {
    max-width: var(--wrap);
    display: grid;
    grid-template-columns: minmax(0, var(--wrap-narrow)) 230px;
    justify-content: center;
    gap: 44px;
    align-items: start;
  }
  .post-primary {
    min-width: 0;
  }
  .post-main {
    width: 100%;
  }

  .toc {
    min-width: 0;
    position: sticky;
    top: 94px;
    align-self: start;
  }
  .toc-inner {
    max-height: calc(100vh - 114px);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    border-top: 1px solid var(--border);
    padding-top: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--text-dim) transparent;
  }
  .toc-inner::-webkit-scrollbar { width: 10px; }
  .toc-inner::-webkit-scrollbar-track { background: transparent; }
  .toc-inner::-webkit-scrollbar-thumb {
    background: var(--text-dim);
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: padding-box;
  }
  .toc-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--text-dim);
    margin-bottom: 10px;
  }
  .toc-nav {
    display: grid;
  }
  .toc-link {
    font-size: 13px;
    color: var(--text-dim);
    text-decoration: none;
    line-height: 1.45;
    padding: 6px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }
  .toc-link:hover {
    color: var(--accent-bright);
  }
  .toc-link.depth-3 {
    padding-left: 12px;
    font-size: 12px;
  }

  .post-footer {
    padding: 24px 0;
    margin-top: 36px;
    border-top: 1px solid var(--border);
  }
  .tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 4px 10px;
    border-radius: 2px;
    letter-spacing: 0.05em;
  }

  @media (max-width: 1100px) {
    .post-shell.has-toc {
      max-width: var(--wrap-narrow);
      display: block;
    }
    .toc {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .post-shell {
      padding: 0 20px;
    }
    .post-header { padding: 56px 0 32px; }
    .post-header h1 { font-size: 28px; }
    .post-footer {
      padding: 20px 0;
      margin-top: 28px;
    }
  }

  .post-body :global(img) {
    cursor: zoom-in;
  }
  .image-lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    cursor: zoom-out;
  }
  .image-lightbox[hidden] { display: none; }
  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    user-select: none;
  }
  .lightbox-close {
    position: fixed;
    top: 20px;
    right: 24px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    font-size: 28px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.16);
  }
</style>

<script>
  const lightbox = document.getElementById('image-lightbox') as HTMLElement | null;
  const lightboxImg = lightbox?.querySelector('.lightbox-img') as HTMLImageElement | null;
  const closeBtn = lightbox?.querySelector('.lightbox-close') as HTMLButtonElement | null;
  const body = document.querySelector('.post-body');

  function open(src: string, alt: string) {
    if (!lightbox || !lightboxImg) return;
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function close() {
    if (!lightbox || !lightboxImg) return;
    lightbox.hidden = true;
    lightboxImg.src = '';
    document.body.style.overflow = '';
  }

  body?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === 'IMG') {
      const img = target as HTMLImageElement;
      if (img.closest('a')) return;
      e.preventDefault();
      open(img.currentSrc || img.src, img.alt);
    }
  });
  lightbox?.addEventListener('click', (e) => {
    if (e.target === closeBtn || e.target === lightbox) close();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox && !lightbox.hidden) close();
  });
</script>
