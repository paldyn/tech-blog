---
import { NAV_LINKS, SITE_SUFFIX } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import { getPublishedPosts, postUrl } from '../utils/posts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(base, '') || '/';
const posts = await getPublishedPosts();

const searchItems = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  tags: post.data.tags,
  author: post.data.author ?? 'PALDYN',
  pubDate: post.data.pubDate.toISOString().slice(0, 10),
  url: postUrl(post),
  searchText: [
    post.data.title,
    post.data.description,
    post.data.category,
    post.data.tags.join(' '),
    post.data.author ?? 'PALDYN',
  ].join(' ').toLowerCase(),
}));
---

<header class="site-header">
  <div class="wrap">
    <div class="header-inner">
      <a href={`${base}/`} class="nav-logo">
        <img class="logo-symbol logo-light" src={`${base}/assets/logo-symbol-dark.png`} alt="PALDYN" />
        <img class="logo-symbol logo-dark" src={`${base}/assets/logo-symbol-light.png`} alt="PALDYN" />
        <span class="logo-text">PALDYN</span>
        <span class="logo-divider">|</span>
        <span class="logo-suffix">{SITE_SUFFIX}</span>
      </a>

      <nav class="main-nav">
        {NAV_LINKS.map(({ href, label }) => {
          const fullHref = `${base}${href}`;
          const active = pathname === href || (href !== '/' && pathname.startsWith(href));
          return <a href={fullHref} class:list={[{ active }]}>{label}</a>;
        })}
      </nav>

      <div class="nav-right">
        <div class="nav-search" id="navSearch">
          <svg class="search-mark" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0"></path>
          </svg>
          <input
            id="navSearchInput"
            type="search"
            autocomplete="off"
            placeholder="'/'로 검색"
            aria-label="Search posts"
          />

          <div class="search-panel" hidden>
            <p class="search-caption" hidden></p>
            <ul class="search-results"></ul>
            <p class="search-empty" hidden>검색 결과가 없습니다.</p>
          </div>

          <script type="application/json" class="search-index" set:html={JSON.stringify(searchItems)}></script>
        </div>

        <ThemeToggle />
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var root = document.getElementById('navSearch');
      if (!root) return;

      var input = root.querySelector('#navSearchInput');
      var panel = root.querySelector('.search-panel');
      var caption = root.querySelector('.search-caption');
      var list = root.querySelector('.search-results');
      var empty = root.querySelector('.search-empty');
      var raw = root.querySelector('.search-index');
      if (!input || !panel || !caption || !list || !empty || !raw) return;

      var index = [];
      try {
        index = JSON.parse(raw.textContent || '[]');
      } catch (e) {
        index = [];
      }

      function formatDate(isoDate) {
        if (!isoDate) return '';
        return isoDate.replace(/-/g, '.');
      }

      function closePanel() {
        panel.hidden = true;
        root.classList.remove('open');
      }

      function openPanel() {
        panel.hidden = false;
        root.classList.add('open');
      }

      function render(query) {
        var q = query.trim().toLowerCase();
        list.innerHTML = '';
        caption.hidden = true;
        empty.hidden = true;

        if (!q) {
          closePanel();
          return;
        }

        var results = index
          .filter(function (item) { return item.searchText.indexOf(q) !== -1; })
          .slice(0, 8);

        if (results.length === 0) {
          openPanel();
          caption.hidden = false;
          caption.textContent = '검색 결과 0건';
          empty.hidden = false;
          return;
        }

        caption.hidden = false;
        caption.textContent = '검색 결과 ' + results.length + '건';

        var fragment = document.createDocumentFragment();
        results.forEach(function (item, idx) {
          var li = document.createElement('li');
          li.style.position = 'relative';
          if (idx > 0) {
            li.style.marginTop = '10px';
            li.style.paddingTop = '10px';
            li.style.borderTop = '1px solid var(--border)';
          }

          var a = document.createElement('a');
          a.href = item.url;
          a.className = 'search-link';
          a.style.display = 'grid';
          a.style.gridTemplateColumns = '30px minmax(0, 1fr)';
          a.style.columnGap = '10px';
          a.style.alignItems = 'start';
          a.style.textDecoration = 'none';
          a.style.padding = '10px 12px';
          a.style.border = '1px solid var(--border)';
          a.style.borderRadius = '10px';
          a.style.background = 'var(--bg)';
          a.style.color = 'var(--text)';

          var order = document.createElement('span');
          order.className = 'search-order';
          order.textContent = String(idx + 1).padStart(2, '0');
          order.style.display = 'inline-flex';
          order.style.width = '22px';
          order.style.height = '22px';
          order.style.alignItems = 'center';
          order.style.justifyContent = 'center';
          order.style.border = '1px solid var(--border)';
          order.style.borderRadius = '999px';
          order.style.fontFamily = 'var(--font-mono)';
          order.style.fontSize = '10px';
          order.style.color = 'var(--text-dim)';
          order.style.lineHeight = '1';
          order.style.marginTop = '1px';
          a.appendChild(order);

          var body = document.createElement('span');
          body.className = 'search-body';
          body.style.minWidth = '0';

          var top = document.createElement('span');
          top.className = 'search-top';
          top.style.display = 'flex';
          top.style.alignItems = 'center';
          top.style.justifyContent = 'space-between';
          top.style.gap = '10px';
          top.style.marginBottom = '7px';

          var cat = document.createElement('span');
          cat.className = 'search-chip';
          cat.textContent = (item.category || 'General').toUpperCase();
          cat.style.display = 'inline-block';
          cat.style.border = '1px solid var(--border)';
          cat.style.borderRadius = '999px';
          cat.style.padding = '1px 7px';
          cat.style.lineHeight = '1.6';
          cat.style.fontSize = '10px';
          cat.style.letterSpacing = '0.08em';
          cat.style.color = 'var(--text-dim)';
          cat.style.background = 'var(--bg)';
          top.appendChild(cat);

          var date = document.createElement('span');
          date.className = 'search-date';
          date.textContent = formatDate(item.pubDate);
          date.style.fontFamily = 'var(--font-mono)';
          date.style.fontSize = '10px';
          date.style.letterSpacing = '0.04em';
          date.style.color = 'var(--text-muted)';
          top.appendChild(date);
          body.appendChild(top);

          var title = document.createElement('strong');
          title.className = 'search-title';
          title.textContent = item.title;
          title.style.display = 'block';
          title.style.fontSize = '13.5px';
          title.style.fontWeight = '600';
          title.style.lineHeight = '1.35';
          title.style.marginBottom = '5px';
          title.style.color = 'var(--accent-bright)';
          title.style.letterSpacing = '0.005em';
          title.style.whiteSpace = 'nowrap';
          title.style.overflow = 'hidden';
          title.style.textOverflow = 'ellipsis';
          body.appendChild(title);

          var desc = document.createElement('span');
          desc.className = 'search-desc';
          desc.textContent = item.description || '';
          desc.style.display = 'block';
          desc.style.fontSize = '11px';
          desc.style.lineHeight = '1.45';
          desc.style.color = 'var(--text-dim)';
          desc.style.marginBottom = '6px';
          desc.style.overflow = 'hidden';
          desc.style.display = '-webkit-box';
          desc.style.webkitLineClamp = '2';
          desc.style.webkitBoxOrient = 'vertical';
          body.appendChild(desc);

          var meta = document.createElement('span');
          meta.className = 'search-meta';
          meta.textContent = [item.author, item.tags.slice(0, 2).map(function (tag) { return '#' + tag; }).join(' ')].filter(Boolean).join(' · ');
          meta.style.display = 'block';
          meta.style.fontFamily = 'var(--font-mono)';
          meta.style.fontSize = '10px';
          meta.style.letterSpacing = '0.04em';
          meta.style.color = 'var(--text-dim)';
          body.appendChild(meta);

          a.appendChild(body);

          li.appendChild(a);
          fragment.appendChild(li);
        });

        list.appendChild(fragment);
        openPanel();
      }

      input.addEventListener('input', function () {
        render(input.value);
      });

      input.addEventListener('focus', function () {
        if (input.value.trim()) render(input.value);
      });

      document.addEventListener('click', function (event) {
        if (!root.contains(event.target)) {
          closePanel();
        }
      });

      document.addEventListener('keydown', function (event) {
        var target = event.target;
        var tag = target && target.tagName ? String(target.tagName).toUpperCase() : '';
        var isTypingTarget = !!(target && (
          target.isContentEditable ||
          tag === 'INPUT' ||
          tag === 'TEXTAREA' ||
          tag === 'SELECT'
        ));

        if (event.key === 'Escape') {
          closePanel();
          input.blur();
        }

        if (
          event.key === '/' &&
          !event.metaKey &&
          !event.ctrlKey &&
          !event.altKey &&
          !isTypingTarget
        ) {
          event.preventDefault();
          input.focus();
          input.select();
          return;
        }

        if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
          event.preventDefault();
          input.focus();
          input.select();
        }
      });
    })();
  </script>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 18px 0;
    background: var(--bg);
    transition: background 0.4s, border-color 0.4s;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    height: 28px;
  }
  .logo-symbol {
    height: 28px;
    width: auto;
  }
  .logo-text {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--accent-bright);
    line-height: 1;
    margin-left: 2px;
  }

  .logo-light { display: block; }
  .logo-dark { display: none; }
  :global([data-theme="dark"]) .logo-light { display: none; }
  :global([data-theme="dark"]) .logo-dark { display: block; }

  .logo-divider {
    color: var(--border);
    font-weight: 300;
    font-size: 18px;
    margin: 0 2px;
  }
  .logo-suffix {
    font-size: 13px;
    color: var(--text-dim);
    letter-spacing: 0.08em;
    font-weight: 400;
  }

  .main-nav {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }
  .main-nav a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.08em;
    transition: color 0.25s;
    position: relative;
  }
  .main-nav a:hover { color: var(--accent-bright); }
  .main-nav a.active { color: var(--accent-bright); }
  .main-nav a.active::after {
    content: '';
    position: absolute;
    bottom: -6px; left: 0; right: 0;
    height: 1px;
    background: var(--accent-bright);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-search {
    position: relative;
    width: min(206px, 42vw);
    min-width: 164px;
  }
  .nav-search input {
    width: 100%;
    height: 32px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--bg);
    color: var(--text);
    font-size: 12px;
    letter-spacing: 0.02em;
    padding: 0 12px 0 34px;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
  }
  .nav-search input::placeholder { color: var(--text-muted); }
  .nav-search input:focus {
    border-color: var(--text-dim);
    background: var(--bg-subtle);
  }
  .search-mark {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-dim);
    width: 16px;
    height: 16px;
    display: block;
    stroke: currentColor;
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    pointer-events: none;
  }

  :global(#navSearch .search-panel) {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: min(430px, 80vw);
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 14px;
    max-height: 380px;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--text-dim) transparent;
    z-index: 50;
    padding: 8px 8px 10px;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(8px);
  }
  :global([data-theme="dark"] #navSearch .search-panel) {
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.4);
    scrollbar-color: #5b5b5b transparent;
  }
  :global(#navSearch .search-panel::-webkit-scrollbar) {
    width: 10px;
  }
  :global(#navSearch .search-panel::-webkit-scrollbar-track) {
    background: transparent;
  }
  :global(#navSearch .search-panel::-webkit-scrollbar-thumb) {
    background: #b6b6b6;
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: padding-box;
  }
  :global([data-theme="dark"] #navSearch .search-panel::-webkit-scrollbar-thumb) {
    background: #555555;
    border: 2px solid transparent;
    background-clip: padding-box;
  }
  :global(#navSearch .search-caption) {
    margin: 0;
    padding: 4px 8px 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.09em;
    color: var(--text-dim);
    text-transform: uppercase;
  }
  :global(#navSearch .search-results) {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  :global(#navSearch .search-results li) {
    position: relative;
  }
  :global(#navSearch .search-results li + li) {
    margin-top: 10px;
  }
  :global(#navSearch .search-results li + li::before) {
    content: '';
    position: absolute;
    top: -6px;
    left: 10px;
    right: 10px;
    border-top: 1px solid var(--border);
    opacity: 0.5;
  }
  :global(#navSearch .search-link) {
    display: block;
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    align-items: start;
    column-gap: 10px;
    text-decoration: none;
    padding: 10px 12px;
    color: var(--text);
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg);
    transition: background 0.18s, border-color 0.18s, transform 0.18s;
  }
  :global(#navSearch .search-link:hover) {
    background: var(--bg);
    border-color: var(--text-muted);
    transform: translateY(-1px);
  }
  :global(#navSearch .search-link:focus-visible) {
    outline: 2px solid var(--text-dim);
    outline-offset: 1px;
  }
  :global(#navSearch .search-order) {
    display: inline-flex;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    border: 1px solid var(--border);
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.01em;
    color: var(--text-dim);
    line-height: 1;
    margin-top: 1px;
  }
  :global(#navSearch .search-body) {
    min-width: 0;
  }
  :global(#navSearch .search-top) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 7px;
  }
  :global(#navSearch .search-chip) {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 1px 7px;
    line-height: 1.6;
    background: var(--bg);
  }
  :global(#navSearch .search-date) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }
  :global(#navSearch .search-title) {
    display: block;
    font-size: 13.5px;
    line-height: 1.35;
    margin-bottom: 5px;
    color: var(--accent-bright);
    letter-spacing: 0.005em;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  :global(#navSearch .search-desc) {
    display: block;
    font-size: 11px;
    line-height: 1.45;
    color: var(--text-dim);
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-decoration: none;
  }
  :global(#navSearch .search-meta) {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    text-decoration: none;
  }
  :global(#navSearch .search-empty) {
    margin: 0;
    padding: 4px 10px 8px;
    font-size: 12px;
    color: var(--text-dim);
  }

  @media (max-width: 780px) {
    .header-inner { gap: 14px; }
    .main-nav { order: 3; width: 100%; gap: 18px; }
    .nav-right { width: 100%; justify-content: space-between; }
    .nav-search { width: calc(100% - 46px); max-width: none; }
    :global(#navSearch .search-panel) {
      left: 0;
      right: auto;
      width: 100%;
    }
    .logo-suffix { font-size: 12px; }
    .logo-divider { font-size: 15px; }
  }
</style>
