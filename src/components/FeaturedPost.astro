---
import FormattedDate from './FormattedDate.astro';

interface Props {
  title: string;
  description: string;
  author?: string;
  pubDate: Date;
  readingTime: string;
  url: string;
  category?: string;
  thumb?: string;
  thumbVariant?: 'a' | 'b' | 'c' | 'd' | 'e' | 'f';
  logo?: string;
}
const {
  title, description, author = 'PALDYN', pubDate, readingTime, url, category,
  thumb = '</>', thumbVariant = 'a', logo,
} = Astro.props;

const shouldFillLogo =
  logo?.endsWith('/javascript.jpeg') ||
  logo?.endsWith('/typescript.svg') ||
  logo?.endsWith('/nexacro.png') ||
  logo?.endsWith('/ai.jpg') ||
  logo?.endsWith('/network.jpg') ||
  logo?.endsWith('/algorithm.jpg') ||
  logo?.endsWith('/nextjs.jpg') ||
  logo?.endsWith('/security.jpg') ||
  logo?.endsWith('/spring.png') ||
  logo?.endsWith('/sql.png') ||
  logo?.endsWith('/java.svg') ||
  logo?.endsWith('/git.png') ||
  logo?.endsWith('/linux.svg') ||
  logo?.endsWith('/docker.png') ||
  logo?.endsWith('/react.png') ||
  logo?.endsWith('/kubernetes.png') ||
  logo?.endsWith('/python.jpg');
const fillClass = logo?.endsWith('/nexacro.png')
  ? 'nexacro-logo-fill'
  : logo?.endsWith('/git.png')
  ? 'git-logo-fill'
  : logo?.endsWith('/docker.png')
  ? 'docker-logo-fill'
  : logo?.endsWith('/react.png')
  ? 'react-logo-fill'
  : logo?.endsWith('/kubernetes.png')
  ? 'kubernetes-logo-fill'
  : undefined;
const useThemeLogo = category === 'Team';
---

<a href={url} class="hero-feature">
  <div class="hero-visual">
    {useThemeLogo ? (
      <div class="hero-thumb logo-thumb team-logo-thumb">
        <img class="team-logo team-logo-light-mode" src="/assets/logo-symbol-light.png" alt={`${category} 로고`} loading="lazy" />
        <img class="team-logo team-logo-dark-mode" src="/assets/logo-symbol-dark.png" alt="" loading="lazy" aria-hidden="true" />
      </div>
    ) : logo ? (
      <div class:list={['hero-thumb', 'logo-thumb', fillClass, { 'logo-fill': shouldFillLogo }]}>
        <img src={logo} alt={`${category} 로고`} loading="lazy" />
      </div>
    ) : (
      <div class={`hero-thumb ${thumbVariant} hero-thumb-pattern`}>
        <span class="bg-rings" aria-hidden="true">
          <span class="ring"></span>
          <span class="ring"></span>
          <span class="ring"></span>
          <span class="ring"></span>
          <span class="core"></span>
        </span>
        <span class="pattern-category" aria-hidden="true">{category?.toUpperCase()}</span>
      </div>
    )}
  </div>

  <div class="hero-body">
    <div class="label-featured">★ FEATURED {category && `· ${category.toUpperCase()}`}</div>
    <h1>{title}</h1>
    <p>{description}</p>
    <div class="hero-meta">
      <span>{readingTime}</span>
      <span class="sep">·</span>
      <FormattedDate date={pubDate} />
      <span class="sep">·</span>
      <span>{author}</span>
      <span class="read-more">READ →</span>
    </div>
  </div>
</a>

<style>
  .hero-feature {
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: var(--gradient-hero);
    color: #ffffff;
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35), inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  :global([data-theme="dark"]) .hero-feature {
    border-color: rgba(255, 255, 255, 0.24);
    box-shadow: 0 16px 50px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.08);
  }
  .hero-feature:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), inset 0 0 0 1px rgba(255, 255, 255, 0.1);
  }

  /* === visual top === */
  .hero-visual {
    position: relative;
    aspect-ratio: 3 / 1;
    overflow: hidden;
    background: #0a0a0a;
  }
  .hero-thumb {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: transform 0.6s ease;
  }
  .hero-feature:hover .hero-thumb { transform: scale(1.03); }

  /* gradient fallback */
  .hero-thumb.a { background: linear-gradient(135deg, #0a0a0a, #2a2a2a); }
  .hero-thumb.b { background: linear-gradient(135deg, #1a1a1a, #353535); }
  .hero-thumb.c { background: linear-gradient(135deg, #111, #1e2028); }
  .hero-thumb.d { background: linear-gradient(135deg, #141414, #2a2a2a); }
  .hero-thumb.e { background: linear-gradient(135deg, #0f0f0f, #222); }
  .hero-thumb.f { background: linear-gradient(135deg, #1c1c1c, #3a3a3a); }
  .pattern-category {
    position: relative;
    z-index: 1;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.4em;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    padding: 8px 16px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    backdrop-filter: blur(4px);
  }
  .bg-rings {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    pointer-events: none;
  }
  .bg-rings .ring {
    position: absolute;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 50%;
    animation: ringRotate 30s linear infinite;
  }
  .bg-rings .ring:nth-child(1) { width: 92%; aspect-ratio: 1; animation-duration: 38s; }
  .bg-rings .ring:nth-child(2) { width: 68%; aspect-ratio: 1; animation-duration: 26s; animation-direction: reverse; }
  .bg-rings .ring:nth-child(3) { width: 44%; aspect-ratio: 1; animation-duration: 32s; }
  .bg-rings .ring:nth-child(4) { width: 22%; aspect-ratio: 1; animation-duration: 18s; animation-direction: reverse; border-color: rgba(255,255,255,0.12); }
  .bg-rings .core {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.4);
  }
  .hero-thumb-pattern {
    background:
      radial-gradient(ellipse at 30% 20%, rgba(126, 153, 186, 0.12) 0%, transparent 50%),
      linear-gradient(135deg, #0d1117, #1a1f2e);
  }
  @keyframes ringRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* logo styles */
  .hero-thumb.logo-thumb { background: #fafafa; padding: 8% 14%; }
  .hero-thumb.logo-thumb img {
    max-width: 60%;
    max-height: 60%;
    object-fit: contain;
  }
  .hero-thumb.logo-thumb.logo-fill { padding: 0; background: transparent; }
  .hero-thumb.logo-thumb.logo-fill.nexacro-logo-fill { background: #00388b; }
  .hero-thumb.logo-thumb.logo-fill.git-logo-fill { background: #f0f0e8; border-color: rgba(0,0,0,0.08); }
  .hero-thumb.logo-thumb.logo-fill.docker-logo-fill { background: #ffffff; border-color: rgba(0,0,0,0.08); }
  .hero-thumb.logo-thumb.logo-fill.react-logo-fill { background: #ffffff; border-color: rgba(0,0,0,0.08); }
  .hero-thumb.logo-thumb.logo-fill.kubernetes-logo-fill { background: #ffffff; border-color: rgba(0,0,0,0.08); }
  .hero-thumb.logo-thumb.logo-fill img {
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    object-fit: cover;
  }
  .hero-thumb.logo-thumb.logo-fill.git-logo-fill img {
    object-fit: contain;
    padding: 0;
    box-sizing: border-box;
    transform: scale(1.2);
  }
  .hero-thumb.logo-thumb.logo-fill.docker-logo-fill img {
    object-fit: contain;
    padding: 8% 6%;
    box-sizing: border-box;
  }
  .hero-thumb.logo-thumb.logo-fill.react-logo-fill img {
    object-fit: contain;
    padding: 0;
    box-sizing: border-box;
    transform: scale(1);
  }
  .hero-thumb.logo-thumb.logo-fill.kubernetes-logo-fill img {
    object-fit: contain;
    padding: 0;
    box-sizing: border-box;
    transform: scale(1.35);
  }
  .hero-thumb.logo-thumb.team-logo-thumb { background: #050505; padding: 0; }
  .hero-thumb.logo-thumb.team-logo-thumb .team-logo {
    width: 100px; height: 100px;
    object-fit: contain;
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.6s ease;
  }
  .hero-feature:hover .hero-thumb.team-logo-thumb .team-logo {
    transform: translate(-50%, -50%) scale(1.05);
  }
  .hero-thumb.logo-thumb.team-logo-thumb .team-logo-dark-mode { display: none !important; }
  :global(html[data-theme="dark"]) .hero-thumb.logo-thumb.team-logo-thumb { background: #ffffff; }
  :global(html[data-theme="dark"]) .hero-thumb.logo-thumb.team-logo-thumb .team-logo-light-mode { display: none !important; }
  :global(html[data-theme="dark"]) .hero-thumb.logo-thumb.team-logo-thumb .team-logo-dark-mode { display: block !important; }

  /* === text body === */
  .hero-body {
    padding: 20px 26px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .label-featured {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin-bottom: 10px;
  }
  .hero-feature h1 {
    font-size: 22px;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: 0.005em;
    margin: 0 0 10px;
    background: var(--gradient-silver);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hero-feature p {
    color: rgba(255, 255, 255, 0.72);
    font-size: 13.5px;
    line-height: 1.65;
    margin: 0 0 18px;
    font-weight: 300;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .hero-meta {
    display: flex;
    gap: 10px;
    font-size: 11px;
    color: rgba(255,255,255,0.55);
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    align-items: center;
    margin-top: auto;
    flex-wrap: wrap;
  }
  .sep { opacity: 0.5; }
  .read-more {
    margin-left: auto;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.85);
  }

  @media (max-width: 640px) {
    .hero-body { padding: 24px 24px 28px; }
    .hero-feature h1 { font-size: 22px; }
    .hero-feature p { font-size: 13.5px; }
  }
</style>
