---
interface Props {
  date: Date;
  format?: 'dot' | 'long';
}
const { date, format = 'dot' } = Astro.props;
const y = date.getFullYear();
const m = String(date.getMonth() + 1).padStart(2, '0');
const d = String(date.getDate()).padStart(2, '0');
const str = format === 'dot' ? `${y}.${m}.${d}` : `${y}년 ${m}월 ${d}일`;
---
<time datetime={date.toISOString()}>{str}</time>
