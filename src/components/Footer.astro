---
import { SOCIAL_LINKS, OFFICIAL_URL } from '../consts';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="site-footer">
  <div class="wrap">
    <div class="inner">
      <div class="left">© {year} PALDYN. All rights reserved.</div>
      <div class="links">
        <a class="official-brand" href={OFFICIAL_URL} target="_blank" rel="noopener" aria-label="PALDYN 공식 웹사이트">
          <span class="wordmark">PALDYN</span>
          <span class="external">↗</span>
        </a>
        <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener">GitHub</a>
        <a href={`${base}/rss.xml`}>RSS</a>
        <a href={SOCIAL_LINKS.email}>Contact</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 120px;
    padding: 36px 0;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }
  .inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
  }
  .left { font-weight: 400; }
  .links { display: flex; gap: 24px; flex-wrap: wrap; }
  .links a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.25s;
  }
  .links a:hover { color: var(--accent-bright); }
  .links a.official-brand {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    letter-spacing: normal;
  }
  .links a.official-brand .wordmark {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--accent-bright);
    line-height: 1;
  }
  .links a.official-brand .external {
    font-size: 11px;
    color: var(--text-dim);
    transition: color 0.25s;
    line-height: 1;
  }
  .links a.official-brand:hover .external { color: var(--accent-bright); }
  @media (max-width: 640px) {
    .inner { justify-content: flex-start; }
  }
</style>
