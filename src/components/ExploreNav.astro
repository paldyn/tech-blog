---
type ExploreMode = 'all' | 'record' | 'knowledge';
type ExploreSection = 'archive' | 'categories' | 'tags';

interface Props {
  mode: ExploreMode;
  section?: ExploreSection;
  showPrimary?: boolean;
  showSecondary?: boolean;
}

const { mode, section = 'archive', showPrimary = true, showSecondary = true } = Astro.props as Props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const primaryTabs = [
  { mode: 'all' as ExploreMode, label: '전체', href: `${base}/posts/` },
  { mode: 'record' as ExploreMode, label: '기록', href: `${base}/records/` },
  { mode: 'knowledge' as ExploreMode, label: '지식', href: `${base}/knowledge/` },
];

const secondaryTabs = mode === 'record'
  ? [
      { key: 'archive' as ExploreSection, label: '최신순', href: `${base}/records/` },
      { key: 'categories' as ExploreSection, label: '카테고리', href: `${base}/records/categories/` },
      { key: 'tags' as ExploreSection, label: '태그', href: `${base}/records/tags/` },
    ]
  : mode === 'knowledge'
    ? [
        { key: 'archive' as ExploreSection, label: '최신순', href: `${base}/knowledge/` },
        { key: 'categories' as ExploreSection, label: '카테고리', href: `${base}/knowledge/categories/` },
        { key: 'tags' as ExploreSection, label: '태그', href: `${base}/knowledge/tags/` },
      ]
    : [];
---

<div class="explore-nav" aria-label="콘텐츠 탐색">
  {showPrimary && (
    <nav class="primary" aria-label="콘텐츠 유형">
      {primaryTabs.map((tab) => (
        <a
          href={tab.href}
          data-tab-mode={tab.mode}
          class:list={['tab', { active: tab.mode === mode }]}
          aria-current={tab.mode === mode ? 'page' : undefined}
        >
          {tab.label}
        </a>
      ))}
    </nav>
  )}

  {showSecondary && secondaryTabs.length > 0 && (
    <nav class="secondary" aria-label="세부 탐색">
      {secondaryTabs.map((tab) => (
        <a
          href={tab.href}
          class:list={['sub-tab', { active: tab.key === section }]}
          aria-current={tab.key === section ? 'page' : undefined}
        >
          {tab.label}
        </a>
      ))}
    </nav>
  )}
</div>

<style>
  .explore-nav {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }

  .primary {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    border-radius: 999px;
    padding: 4px;
    width: fit-content;
    max-width: 100%;
  }
  .tab {
    text-decoration: none;
    color: var(--text-dim);
    font-size: 12px;
    letter-spacing: 0.04em;
    line-height: 1;
    border-radius: 999px;
    padding: 8px 12px;
    white-space: nowrap;
    transition: color 0.2s, background 0.2s;
  }
  .tab:hover {
    color: var(--accent-bright);
  }
  .tab.active {
    color: var(--bg);
    background: var(--accent-bright);
  }

  .secondary {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
  }
  .sub-tab {
    text-decoration: none;
    color: var(--text);
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    border-radius: 999px;
    padding: 6px 11px;
    font-size: 11px;
    letter-spacing: 0.05em;
    line-height: 1.1;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    white-space: nowrap;
  }
  .sub-tab:hover {
    border-color: var(--text-dim);
    color: var(--accent-bright);
  }
  .sub-tab.active {
    color: var(--bg);
    background: var(--accent-bright);
    border-color: var(--accent-bright);
  }

  @media (max-width: 640px) {
    .explore-nav {
      margin-top: 12px;
    }
    .primary {
      width: 100%;
      overflow-x: auto;
      scrollbar-width: none;
      justify-content: flex-start;
    }
    .primary::-webkit-scrollbar { display: none; }
  }
</style>
