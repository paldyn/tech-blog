---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExploreNav from '../../components/ExploreNav.astro';
import { getPostsByType, postUrl } from '../../utils/posts';

const posts = await getPostsByType('knowledge');
const newWindowMs = 1000 * 60 * 60 * 24 * 30;

function isNew(pubDate: Date): boolean {
  return Date.now() - pubDate.getTime() <= newWindowMs;
}

function dotDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}.${m}.${d}`;
}
---

<BaseLayout title="Knowledge">
  <div class="wrap">
    <header class="page-header" id="all-knowledge">
      <div class="label">KNOWLEDGE</div>
      <h1>지식</h1>
      <p>지식형 글을 최신 발행순으로 모아 본 페이지입니다.</p>
      <ExploreNav mode="knowledge" section="archive" showPrimary={false} />
    </header>

    {posts.length > 0 ? (
      <section class="main" aria-label="최신 지식 글 목록">
        <ul class="rows">
          {posts.map((post) => (
            <li>
              <div class="post-main">
                <a href={postUrl(post)}>{post.data.title}</a>
                {isNew(post.data.pubDate) && <span class="badge">NEW</span>}
              </div>
              <time datetime={post.data.pubDate.toISOString()}>{dotDate(post.data.pubDate)}</time>
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <section class="empty">
        <h2>아직 지식 글이 없습니다.</h2>
        <p>글 frontmatter에 <code>type: "knowledge"</code>를 넣으면 이 페이지에 자동으로 표시됩니다.</p>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 76px 0 32px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 36px;
  }
  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.28em;
    margin-bottom: 14px;
  }
  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    margin-bottom: 10px;
    color: var(--accent-bright);
  }
  .page-header p {
    color: var(--text-dim);
    font-size: 14px;
  }

  .main {
    margin-bottom: 80px;
  }

  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
  }
  .rows li {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 10px;
    min-height: 40px;
    border-bottom: 1px solid var(--border);
    padding: 8px 0;
  }
  .rows li:first-child {
    border-top: 1px solid var(--border);
  }
  .post-main {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .rows time {
    justify-self: end;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .post-main a {
    color: var(--text);
    text-decoration: none;
    font-size: 1.05rem;
    line-height: 1.4;
  }
  .post-main a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .badge {
    background: #ff6400;
    color: #ffffff;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    line-height: 1;
    padding: 5px 7px 4px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .empty {
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    padding: 36px 28px;
    margin-bottom: 80px;
  }
  .empty h2 {
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 10px;
    color: var(--accent-bright);
  }
  .empty p {
    color: var(--text-dim);
    font-size: 14px;
  }
  .empty code {
    font-family: var(--font-mono);
    font-size: 0.95em;
  }

  @media (max-width: 640px) {
    .page-header {
      padding-top: 56px;
    }
    .page-header h1 {
      font-size: 1.8rem;
    }
    .rows li {
      grid-template-columns: 1fr;
      align-items: flex-start;
      gap: 6px 8px;
      padding-bottom: 10px;
    }
    .post-main {
      flex-wrap: wrap;
      align-items: flex-start;
      gap: 6px 8px;
    }
    .rows time {
      justify-self: end;
    }
    .post-main a {
      flex-basis: 100%;
      font-size: 1rem;
    }
  }
</style>
