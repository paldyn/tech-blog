---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExploreNav from '../../components/ExploreNav.astro';
import PostList from '../../components/PostList.astro';
import { getPostsByType } from '../../utils/posts';

const posts = await getPostsByType('record');
---

<BaseLayout title="Records">
  <div class="wrap">
    <header class="page-header" id="all-records">
      <div class="label">RECORDS</div>
      <h1>기록</h1>
      <p>기록형 글을 최신 발행순으로 모아 본 페이지입니다.</p>
      <ExploreNav mode="record" section="archive" showPrimary={false} />
    </header>

    {posts.length > 0 ? (
      <PostList posts={posts} ariaLabel="최신 기록 글 목록" />
    ) : (
      <section class="empty">
        <h2>아직 기록 글이 없습니다.</h2>
        <p>글 frontmatter에 <code>type: "record"</code>를 넣으면 이 페이지에 자동으로 표시됩니다.</p>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 76px 0 32px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 36px;
  }
  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.28em;
    margin-bottom: 14px;
  }
  .page-header h1 {
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    margin-bottom: 10px;
    color: var(--accent-bright);
  }
  .page-header p {
    color: var(--text-dim);
    font-size: 14px;
  }

  .empty {
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    padding: 36px 28px;
    margin-bottom: 80px;
  }
  .empty h2 {
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 10px;
    color: var(--accent-bright);
  }
  .empty p {
    color: var(--text-dim);
    font-size: 14px;
  }
  .empty code {
    font-family: var(--font-mono);
    font-size: 0.95em;
  }

  @media (max-width: 640px) {
    .page-header {
      padding-top: 56px;
    }
    .page-header h1 {
      font-size: 1.8rem;
    }
  }
</style>
