---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getPublishedPosts,
  getTags,
  tagSlug,
  postUrl,
} from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = await getTags();

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.some((t) => tagSlug(t) === tag.slug)),
    },
  }));
}

const { tag, posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const newWindowMs = 1000 * 60 * 60 * 24 * 30;
function isNew(pubDate: Date): boolean {
  return Date.now() - pubDate.getTime() <= newWindowMs;
}
function dotDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}.${m}.${d}`;
}
---

<BaseLayout title={`#${tag.name}`}>
  <div class="wrap">
    <header class="page-header">
      <div class="label">TAG</div>
      <h1>#{tag.name}</h1>
      <p>{posts.length}개의 글이 있습니다.</p>
    </header>

    <nav class="sub-nav">
      <a href={`${base}/tags/`} class="sub-link">← All tags</a>
    </nav>

    {posts.length > 0 ? (
      <ul class="posts">
        {posts.map((post) => (
          <li>
            <a href={postUrl(post)}>{post.data.title}</a>
            {isNew(post.data.pubDate) && <span class="badge">NEW</span>}
            <time datetime={post.data.pubDate.toISOString()}>{dotDate(post.data.pubDate)}</time>
          </li>
        ))}
      </ul>
    ) : (
      <section class="empty">
        <h2>아직 글이 없습니다.</h2>
        <p>이 태그의 첫 글을 준비 중입니다.</p>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 80px 0 40px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.3em;
    margin-bottom: 16px;
  }
  .page-header h1 {
    font-size: 2.4rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    margin-bottom: 10px;
    color: var(--accent-bright);
  }
  .page-header p { color: var(--text-dim); font-size: 14px; font-weight: 300; }

  .sub-nav {
    display: flex;
    gap: 4px;
    margin-bottom: 32px;
  }
  .sub-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    text-decoration: none;
    padding: 8px 14px;
    border: 1px solid var(--border);
    white-space: nowrap;
    text-transform: uppercase;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .sub-link:hover { color: var(--accent-bright); border-color: var(--text-dim); }

  .posts {
    list-style: none;
    margin: 0 0 80px;
    padding: 0;
    display: grid;
    gap: 8px;
    border-top: 1px solid var(--border);
    padding-top: 16px;
  }
  .posts li {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 28px;
  }
  .posts time {
    margin-left: auto;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .posts a {
    flex: 1;
    min-width: 0;
    color: var(--text);
    text-decoration: none;
    font-size: 1.05rem;
    line-height: 1.4;
  }
  .posts a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .badge {
    background: #ff6400;
    color: #ffffff;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    line-height: 1;
    padding: 5px 7px 4px;
    border-radius: 3px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .posts li {
      flex-wrap: wrap;
      align-items: flex-start;
      gap: 6px 8px;
      border-bottom: 1px dashed var(--border);
      padding-bottom: 10px;
    }
    .posts a { flex-basis: 100%; font-size: 1rem; }
    .posts time { margin-left: auto; }
  }

  .empty {
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    padding: 36px 28px;
  }
  .empty h2 {
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 10px;
    color: var(--accent-bright);
  }
  .empty p {
    color: var(--text-dim);
    font-size: 14px;
  }
</style>
