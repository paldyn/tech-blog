---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import {
  getPublishedPosts,
  getTags,
  tagSlug,
  readingTimeFor,
  thumbFor,
  variantFor,
  postUrl,
  logoFor,
} from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tags = await getTags();

  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: {
      tag,
      tags,
      posts: posts.filter((post) => post.data.tags.some((t) => tagSlug(t) === tag.slug)),
    },
  }));
}

const { tag, tags, posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={`#${tag.name}`}>
  <div class="wrap">
    <header class="page-header">
      <div class="label">TAG</div>
      <h1>#{tag.name}</h1>
      <p>{posts.length}개의 글이 있습니다.</p>
    </header>

    <nav class="sub-nav">
      <a href={`${base}/tags/`} class="sub-link">All</a>
      {tags.map((t) => (
        <a
          href={`${base}/tags/${t.slug}/`}
          class:list={['sub-link', { active: t.slug === tag.slug }]}
        >#{t.name}</a>
      ))}
    </nav>

    {posts.length > 0 ? (
      <div class="grid">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            author={post.data.author}
            pubDate={post.data.pubDate}
            readingTime={readingTimeFor(post)}
            category={post.data.category}
            url={postUrl(post)}
            thumb={thumbFor(post)}
            thumbVariant={variantFor(post)}
            logo={logoFor(post)}
          />
        ))}
      </div>
    ) : (
      <section class="empty">
        <h2>아직 글이 없습니다.</h2>
        <p>이 태그의 첫 글을 준비 중입니다.</p>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 80px 0 40px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 32px;
  }
  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.3em;
    margin-bottom: 16px;
  }
  .page-header h1 {
    font-size: 2.4rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    margin-bottom: 10px;
    color: var(--accent-bright);
  }
  .page-header p { color: var(--text-dim); font-size: 14px; font-weight: 300; }

  .sub-nav {
    display: flex;
    gap: 4px;
    margin-bottom: 48px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 2px;
  }
  .sub-nav::-webkit-scrollbar { display: none; }
  .sub-link {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    text-decoration: none;
    padding: 8px 14px;
    border: 1px solid var(--border);
    white-space: nowrap;
    text-transform: uppercase;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .sub-link:hover { color: var(--accent-bright); border-color: var(--text-dim); }
  .sub-link.active {
    color: var(--bg);
    background: var(--accent-bright);
    border-color: var(--accent-bright);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }
  @media (max-width: 600px) {
    .grid { grid-template-columns: 1fr; }
  }

  .empty {
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    padding: 36px 28px;
  }
  .empty h2 {
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 10px;
    color: var(--accent-bright);
  }
  .empty p {
    color: var(--text-dim);
    font-size: 14px;
  }
</style>
