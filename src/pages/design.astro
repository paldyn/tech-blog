---
import BaseLayout from '../layouts/BaseLayout.astro';

const options = [
  {
    key: '1-minimal',
    name: 'Minimal',
    note: '세리프 중심, 텍스트 집중형',
    href: '/design/1-minimal.html',
  },
  {
    key: '2-terminal',
    name: 'Terminal',
    note: '개발자 콘솔 무드, 밀도 높은 정보형',
    href: '/design/2-terminal.html',
  },
  {
    key: '3-magazine',
    name: 'Magazine',
    note: '편집 디자인 스타일, 히어로 중심형',
    href: '/design/3-magazine.html',
  },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Design Preview" description="디자인 시안 미리보기">
  <section class="wrap page-head">
    <p class="label">DESIGN LAB</p>
    <h1>디자인 시안 비교</h1>
    <p class="desc">현재 시안 3개를 한 화면에서 비교하고, 마음에 드는 방향으로 바로 본사이트에 반영합니다.</p>
  </section>

  <section class="wrap cards">
    {options.map((opt) => {
      const link = `${base}${opt.href}`;
      return (
        <article class="card">
          <div class="card-head">
            <div>
              <p class="card-label">OPTION</p>
              <h2>{opt.name}</h2>
            </div>
            <a href={link} target="_blank" rel="noopener">새 창으로 보기 ↗</a>
          </div>

          <p class="note">{opt.note}</p>

          <div class="frame-wrap">
            <iframe src={link} title={`${opt.name} mockup`} loading="lazy" />
          </div>
        </article>
      );
    })}
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-top: 70px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 36px;
  }
  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--text-dim);
    margin-bottom: 14px;
  }
  h1 {
    font-size: 2.1rem;
    font-weight: 300;
    color: var(--accent-bright);
    margin-bottom: 10px;
    letter-spacing: 0.01em;
  }
  .desc {
    color: var(--text-dim);
    max-width: 680px;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 26px;
    padding-bottom: 32px;
  }
  .card {
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    padding: 18px;
  }
  .card-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 0.18em;
    margin-bottom: 8px;
  }
  .card h2 {
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--accent-bright);
  }
  .card-head a {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    text-decoration: none;
  }
  .card-head a:hover { color: var(--accent-bright); }

  .note {
    margin: 10px 0 14px;
    color: var(--text-dim);
    font-size: 14px;
  }

  .frame-wrap {
    width: 100%;
    height: 540px;
    border: 1px solid var(--border);
    background: #fff;
    overflow: hidden;
  }
  iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 820px) {
    .frame-wrap { height: 460px; }
  }

  @media (max-width: 640px) {
    .page-head { padding-top: 56px; }
    h1 { font-size: 1.7rem; }
    .frame-wrap { height: 400px; }
  }
</style>
